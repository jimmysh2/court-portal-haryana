# ============================================================
# Court Portal - Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# ============================================================

# ─── ENVIRONMENT ────────────────────────────────────────────
# Set to "development" for local dev, "production" for docker/server deploy
NODE_ENV=development

# ─── SERVER ─────────────────────────────────────────────────
PORT=3000

# ─── DATABASE ────────────────────────────────────────────────
# LOCAL (Docker PostgreSQL) - used when NODE_ENV=development via docker-compose
#DATABASE_URL="postgresql://postgres:Hosting@123@db:5432/court_portal"
#DIRECT_URL="postgresql://postgres:Hosting@123@db:5432/court_portal"

# PRODUCTION (Supabase) - used in Vercel / live deployment
DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT>.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT>.supabase.co:5432/postgres"
SUPABASE_URL="https://<PROJECT>.supabase.co"
SUPABASE_ANON_KEY="<YOUR_SUPABASE_ANON_KEY>"

# ─── SECURITY ────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-secure-random-string"
JWT_REFRESH_SECRET="change-me-too-another-secure-random-string"

# ─── CORS ────────────────────────────────────────────────────
# For docker/local: http://localhost:3000 (frontend served by backend)
# For local dev (vite): http://localhost:5173
CORS_ORIGIN="http://localhost:5173"

# ─── FEATURE FLAGS ──────────────────────────────────────────
VITE_ENABLE_QUICK_LOGIN="true"

# ─── GOOGLE DRIVE BACKUP (optional) ─────────────────────────
GD_FOLDER_ID=
GD_SERVICE_ACCOUNT_JSON=

# ─── AI / GROQ (optional) ───────────────────────────────────
GROQ_API_KEY=
