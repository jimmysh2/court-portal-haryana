# ─────────────────────────────────────────────────────────────
# Naib Court Portal — Environment Variables
# Copy this file to .env and fill in all values before deploying
# ─────────────────────────────────────────────────────────────

# ── Database Credentials ──────────────────────────────────────
# These are used by docker-compose to create the Postgres container
# and by the app to connect to it.
DB_USER=court_user
DB_PASSWORD=replace-me-with-a-strong-password
DB_NAME=court_portal

# DATABASE_URL is built automatically by docker-compose from the above.
# Only set this manually if you are NOT using docker-compose (e.g. Render).
# DATABASE_URL=postgresql://court_user:password@db:5432/court_portal?schema=public

# ── App Settings ──────────────────────────────────────────────
APP_PORT=3000

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string

# ── ☁️ Google Drive Backup Configuration ──────────────────────
# 1. Create a Google Cloud Project and Enable Google Drive API
# 2. Create a Service Account and download the JSON key file
# 3. Open the JSON file, copy the entire content, and paste it below
GD_FOLDER_ID=your-google-drive-folder-id
GD_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"..."}
