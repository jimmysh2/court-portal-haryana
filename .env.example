# ──────────────────────────────────────────────────────────────
#  Naib Court Portal — Environment Variables
#  Copy this file to .env and fill in your production values.
#  ⚠️  Never commit .env to git!
# ──────────────────────────────────────────────────────────────

# ── Database (used by docker-compose to create the Postgres container) ────────
DB_USER=court_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=court_portal

# ── Database URL (consumed by Prisma inside the app container) ────────────────
# For Docker Compose the host must be "db" (the service name).
# Change host to "localhost" if running without Docker Compose.
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}?schema=public

# ── App Port (optional — defaults to 3000) ───────────────────────────────────
PORT=3000

# ── Security — replace with long, random strings ─────────────────────────────
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string

NODE_ENV=production

# ── Google Drive Backup (optional) ───────────────────────────────────────────
# 1. Create a Google Cloud Project and enable the Drive API
# 2. Create a Service Account and download the JSON key
# 3. Paste the entire JSON content on one line below
GD_FOLDER_ID=16_EYYC-w5KvBQ-ysSJ21IWu_O6Ji2Znj
GD_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"..."}
