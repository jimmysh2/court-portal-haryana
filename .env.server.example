# ============================================================
# Court Portal - Server Environment Configuration
# ============================================================
# INSTRUCTIONS FOR IT DEPARTMENT:
#
# 1. Copy this file:   copy .env.server.example .env.server
# 2. Fill in the values below with the actual server settings
# 3. Run:              install.bat
#
# This file will be automatically copied to .env during install.
# NEVER share this file or commit it to git.
# ============================================================

# ─── Database (PostgreSQL on this server) ────────────────────
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# Example: postgresql://postgres:MyPass123@localhost:5432/court_portal
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/court_portal"
DIRECT_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/court_portal"

# ─── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ────────────────────────────────────────────────────
# The IP or domain of this server (how users will access it)
# If users access via browser on same machine: http://localhost:3000
# If users access via network IP:              http://192.168.1.X:3000
CORS_ORIGIN=http://localhost:3000

# ─── Security ────────────────────────────────────────────────
# IMPORTANT: Generate strong random strings for these.
# TIP: Use a password manager to generate 32+ character random strings
JWT_SECRET="replace-with-strong-random-string-minimum-32-chars"
JWT_REFRESH_SECRET="replace-with-another-strong-random-string-minimum-32"

# ─── GitHub Webhook (Auto-Deployment) ────────────────────────
# Webhook port must be different from the main App PORT!
WEBHOOK_PORT=4001
# Secret set in GitHub Settings -> Webhooks. Leave blank to disable security (not recommended)
GITHUB_WEBHOOK_SECRET="replace-this-with-github-webhook-secret"

# ─── Feature Flags ───────────────────────────────────────────
VITE_ENABLE_QUICK_LOGIN=false

# ─── Google Drive Backup (Optional) ──────────────────────────
# Leave blank to disable
GD_FOLDER_ID=
GD_SERVICE_ACCOUNT_JSON=

# ─── AI Assistant (Optional) ─────────────────────────────────
# Leave blank to disable
GROQ_API_KEY=
